DJANGO_SETTINGS_MODULE=config.settings.production
OBE_ENV=production
OBE_DEBUG=0
OBE_ALLOWED_HOSTS=obe.example.invalid
DATABASE_URL_FILE=REPLACE_WITH_RUNTIME_DATABASE_URL_FILE
OBE_SECRET_KEY_FILE=REPLACE_WITH_RUNTIME_SECRET_KEY_FILE
# Aktifkan OBE_SECRET_KEY_FALLBACKS_FILE hanya selama overlap rotasi.
CELERY_BROKER_URL=amqps://broker.example.invalid/obe
CELERY_RESULT_BACKEND=rediss://cache.example.invalid/1
CACHE_URL=rediss://cache.example.invalid/0
OBE_DB_CONN_MAX_AGE=60
OBE_DB_CONNECT_TIMEOUT=5
EVIDENCE_ROOT=/app/var/evidence
EVIDENCE_ANTIVIRUS_REQUIRED=1
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
OBE_QUERY_BUDGET=50
OBE_SLOW_QUERY_MS=250
OBE_AI_ENABLED=1
LITELLM_URL=https://ai-gateway.example.invalid
LITELLM_API_KEY_FILE=REPLACE_WITH_RUNTIME_LITELLM_KEY_FILE
OBE_SECRET_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
DATABASE_PASSWORD_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
LITELLM_API_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
