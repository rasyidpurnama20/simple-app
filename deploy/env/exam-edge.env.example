DJANGO_SETTINGS_MODULE=config.settings.exam_edge
OBE_ENV=exam-edge
OBE_DEBUG=0
OBE_ALLOWED_HOSTS=exam-edge.example.invalid
DATABASE_URL_FILE=REPLACE_WITH_RUNTIME_EDGE_DATABASE_URL_FILE
OBE_SECRET_KEY_FILE=REPLACE_WITH_RUNTIME_EDGE_SECRET_KEY_FILE
# Aktifkan *_FALLBACKS_FILE hanya selama overlap rotasi.
CELERY_BROKER_URL=amqps://broker.example.invalid/exam-edge
CELERY_RESULT_BACKEND=rediss://cache.example.invalid/1
CACHE_URL=rediss://cache.example.invalid/0
OBE_DB_CONN_MAX_AGE=60
OBE_DB_CONNECT_TIMEOUT=5
EVIDENCE_ROOT=/app/var/evidence
EVIDENCE_ANTIVIRUS_REQUIRED=0
OBE_QUERY_BUDGET=30
OBE_SLOW_QUERY_MS=150
OBE_AI_ENABLED=0
OBE_EXAM_SIGNING_KEY_FILE=REPLACE_WITH_RUNTIME_EDGE_SIGNING_KEY_FILE
OBE_EXAM_SYNC_TOKEN_FILE=REPLACE_WITH_RUNTIME_EDGE_SYNC_TOKEN_FILE
OBE_SECRET_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
DATABASE_PASSWORD_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
OBE_EXAM_SIGNING_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
OBE_EXAM_SYNC_TOKEN_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
