DJANGO_SETTINGS_MODULE=config.settings.staging
OBE_ENV=staging
OBE_DEBUG=0
OBE_ALLOWED_HOSTS=staging.example.invalid
OBE_CSRF_TRUSTED_ORIGINS=https://staging.example.invalid
OBE_ADMIN_NETWORKS=10.71.0.0/24
OBE_OUTBOUND_ALLOWED_HOSTS=ai-gateway.staging.example.invalid
OBE_LOGIN_LOCK_THRESHOLD=5
OBE_LOGIN_LOCK_SECONDS=900
OBE_DEFAULT_FROM_EMAIL=no-reply@staging.example.invalid
DATABASE_URL_FILE=REPLACE_WITH_RUNTIME_DATABASE_URL_FILE
OBE_SECRET_KEY_FILE=REPLACE_WITH_RUNTIME_SECRET_KEY_FILE
# Aktifkan OBE_SECRET_KEY_FALLBACKS_FILE hanya selama overlap rotasi.
CELERY_BROKER_URL_FILE=REPLACE_WITH_RUNTIME_RABBITMQ_URL_FILE
CELERY_RESULT_BACKEND=rediss://cache.example.invalid/1
CACHE_URL=rediss://cache.example.invalid/0
OBE_SESSION_TTL_SECONDS=3600
OBE_TASK_RESULT_TTL_SECONDS=3600
OBE_TASK_PAYLOAD_LIMIT_BYTES=262144
OBE_OUTBOX_MAX_ATTEMPTS=5
OBE_DB_CONN_MAX_AGE=60
OBE_DB_CONNECT_TIMEOUT=5
OBE_DB_CONNECTION_LIMIT=20
EVIDENCE_ROOT=/app/var/evidence
EVIDENCE_ANTIVIRUS_REQUIRED=1
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
OBE_QUERY_BUDGET=50
OBE_SLOW_QUERY_MS=250
OBE_TELEMETRY_ENABLED=1
OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.example.invalid
OTEL_SERVICE_NAME=obe-apps-staging
OTEL_METRIC_EXPORT_INTERVAL_MS=15000
OBE_BACKUP_SUCCESS_FILE=/run/obe-config/backup-success.timestamp
OBE_AI_ENABLED=1
LITELLM_URL=https://ai-gateway.example.invalid
LITELLM_API_KEY_FILE=REPLACE_WITH_RUNTIME_LITELLM_KEY_FILE
OBE_SECRET_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
DATABASE_PASSWORD_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
LITELLM_API_KEY_ROTATED_AT=REPLACE_WITH_ISO8601_TIMESTAMP
