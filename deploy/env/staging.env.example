DJANGO_SETTINGS_MODULE=config.settings.staging
OBE_ENV=staging
OBE_DEBUG=0
OBE_ALLOWED_HOSTS=staging.obe.example.ac.id
DATABASE_URL_FILE=/run/secrets/database_url
OBE_SECRET_KEY_FILE=/run/secrets/obe_secret_key
# Aktifkan OBE_SECRET_KEY_FALLBACKS_FILE hanya selama overlap rotasi.
CELERY_BROKER_URL=amqps://broker.obe.example.ac.id/obe
CELERY_RESULT_BACKEND=rediss://cache.obe.example.ac.id/1
CACHE_URL=rediss://cache.obe.example.ac.id/0
OBE_AI_ENABLED=1
LITELLM_URL=https://ai-gateway.obe.example.ac.id
LITELLM_API_KEY_FILE=/run/secrets/litellm_api_key
OBE_SECRET_KEY_ROTATED_AT=2026-07-01T00:00:00+07:00
DATABASE_PASSWORD_ROTATED_AT=2026-07-01T00:00:00+07:00
LITELLM_API_KEY_ROTATED_AT=2026-07-01T00:00:00+07:00
