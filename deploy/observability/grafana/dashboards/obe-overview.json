{
  "title": "OBE Operations Overview",
  "uid": "obe-operations",
  "schemaVersion": 41,
  "refresh": "30s",
  "tags": ["obe", "slo"],
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Core read p95", "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(obe_obe_http_duration_seconds_bucket[5m])))"}]},
    {"id": 2, "type": "stat", "title": "Availability", "targets": [{"expr": "1 - (sum(rate(obe_obe_http_requests_total{http_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(obe_obe_http_requests_total[5m])), 1))"}]},
    {"id": 3, "type": "timeseries", "title": "CPU and RAM", "targets": [{"expr": "rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])"}, {"expr": "node_memory_MemAvailable_bytes"}]},
    {"id": 4, "type": "timeseries", "title": "Disk", "targets": [{"expr": "node_filesystem_avail_bytes"}]},
    {"id": 5, "type": "timeseries", "title": "DB pool", "targets": [{"expr": "obe_obe_db_pool_in_use"}, {"expr": "obe_obe_db_pool_limit"}]},
    {"id": 6, "type": "timeseries", "title": "Queue depth", "targets": [{"expr": "rabbitmq_queue_messages_ready"}]},
    {"id": 7, "type": "timeseries", "title": "Cache hit", "targets": [{"expr": "redis_keyspace_hits_total / clamp_min(redis_keyspace_hits_total + redis_keyspace_misses_total, 1)"}]},
    {"id": 8, "type": "timeseries", "title": "AI tokens", "targets": [{"expr": "rate(obe_obe_ai_tokens_total[5m])"}]},
    {"id": 9, "type": "timeseries", "title": "Failed jobs", "targets": [{"expr": "sum(rate(obe_obe_task_executions_total{outcome=\"failure\"}[5m]))"}]},
    {"id": 10, "type": "logs", "title": "Correlation trace", "datasource": {"type": "loki", "uid": "Loki"}, "targets": [{"expr": "{service_name=~\"obe.*\"} | json | correlation_id != \"\""}]}
  ]
}
