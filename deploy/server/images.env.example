# Semua nilai wajib menggunakan digest immutable yang disetujui registry institusi.
OBE_IMAGE=registry.example.invalid/obe/apps@sha256:REPLACE_WITH_64_HEX_DIGEST
POSTGRES_IMAGE=postgres:17.5-alpine@sha256:REPLACE_WITH_64_HEX_DIGEST
VALKEY_IMAGE=valkey/valkey:8.1.2-alpine@sha256:REPLACE_WITH_64_HEX_DIGEST
RABBITMQ_IMAGE=rabbitmq:4.1.1-management-alpine@sha256:REPLACE_WITH_64_HEX_DIGEST
CLAMAV_IMAGE=clamav/clamav:stable@sha256:REPLACE_WITH_64_HEX_DIGEST
NGINX_IMAGE=nginx:1.28.0-alpine@sha256:REPLACE_WITH_64_HEX_DIGEST
OBE_SECRET_DIR=REPLACE_WITH_ABSOLUTE_SECRET_DIRECTORY
OBE_ENV_FILE=REPLACE_WITH_ABSOLUTE_RUNTIME_ENV_FILE
OBE_DATA_ROOT=REPLACE_WITH_ABSOLUTE_DATA_ROOT
